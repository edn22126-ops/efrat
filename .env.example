# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used locally via docker-compose)
DATABASE_URL=postgresql://plms:plms@localhost:5432/plms

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket where documents are stored (must exist before first run)
S3_BUCKET=plms-documents

# SQS queue URL for OCR jobs (leave empty to skip queueing)
SQS_OCR_QUEUE_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
PRESIGNED_URL_EXPIRY=3600
