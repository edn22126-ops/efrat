# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (Postgres) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://efrat:efrat@localhost:5432/efrat

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME

# S3 bucket for evidence files
S3_BUCKET=efrat-evidence-files

# SQS queue URL for OCR jobs
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/efrat-ocr-jobs

# ── OCR (AWS Textract) ────────────────────────────────────────────────────────
TEXTRACT_REGION=us-east-1
